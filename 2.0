<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stroller Friendly Trails | PNW</title>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    
    <meta name="google-site-verification" content="e_IEe_mgp58Mw7TyH2IWBPhFUQuqyBUYYZ0FSE-vwtk" />
    <link rel="canonical" href="https://www.strollertrails.com" />

    <style>
        :root {
            --primary-green: #2d6a4f;
            --accent-green: #52b788;
            --soft-green: #d8f3dc;
            --light-bg: #fdfdfd;
            --text-dark: #1b4332;
            --text-muted: #555;
            --white: #ffffff;
            --shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            line-height: 1.7;
            background-color: var(--light-bg);
            color: var(--text-dark);
            overflow-x: hidden;
        }

        /* Modern Navigation */
        .navbar {
            background-color: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 1000;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 5%;
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            color: var(--primary-green);
            font-size: 1.4rem;
            text-decoration: none;
        }

        .nav-links a {
            color: var(--text-dark);
            padding: 0.5rem 1rem;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: var(--accent-green);
        }

        /* Hero Section */
        .header {
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.5)), 
                        url("https://media.gettyimages.com/id/1339751014/photo/rain-in-the-forest-vancouver-canada.jpg?s=612x612&w=0&k=20&c=9OWQKb3u7p2DpSDrxDTS7uBqawrjtuKycrcthLVNpZA=");
            background-size: cover;
            background-position: center;
            height: 70vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            color: white;
            padding: 2rem;
        }

        .header h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 8vw, 4.5rem);
            margin-bottom: 1.5rem;
            line-height: 1.1;
        }

        .header p {
            font-size: clamp(1.1rem, 2vw, 1.4rem);
            max-width: 600px;
            font-weight: 300;
            letter-spacing: 0.5px;
        }

        /* Quote Section */
        .quote-container {
            max-width: 800px;
            margin: 6rem auto;
            padding: 0 2rem;
            text-align: center;
        }

        .quote-container h3 {
            font-family: 'Playfair Display', serif;
            font-style: italic;
            font-weight: 400;
            color: var(--text-dark);
            font-size: 1.6rem;
            position: relative;
        }

        /* Grid System */
        .row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
            max-width: 1200px;
            margin: 0 auto 6rem;
            padding: 0 2rem;
        }

        .column {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: all 0.4s ease;
            border: 1px solid rgba(0,0,0,0.03);
        }

        .column:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        .column img {
            width: 100%;
            height: 280px;
            object-fit: cover;
        }

        .column-text {
            padding: 2rem;
            text-align: left;
        }

        .column-text h2 {
            font-size: 1.4rem;
            margin-bottom: 0.5rem;
            color: var(--primary-green);
        }

        /* Footer & Interaction */
        .footer {
            background-color: #f1f3f2;
            padding: 5rem 2rem;
            text-align: center;
        }

        .comment-section {
            max-width: 650px;
            margin: 2rem auto;
            background: white;
            padding: 2rem;
            border-radius: 20px;
            box-shadow: var(--shadow);
        }

        #comment-container {
            margin-bottom: 2rem;
            text-align: left;
        }

        .comment-bubble {
            background: var(--soft-green);
            padding: 12px 18px;
            border-radius: 15px;
            margin-bottom: 10px;
            font-size: 0.95rem;
            display: block;
            width: fit-content;
            max-width: 90%;
        }

        textarea {
            width: 100%;
            padding: 15px;
            border-radius: 12px;
            border: 1px solid #ddd;
            margin-bottom: 1.5rem;
            font-family: inherit;
            resize: vertical;
            min-height: 100px;
        }

        button {
            background-color: var(--primary-green);
            color: white;
            border: none;
            padding: 14px 40px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: 600;
            font-size: 1rem;
            transition: 0.3s;
        }

        button:hover {
            background-color: var(--accent-green);
            transform: scale(1.02);
        }

        .copyright {
            margin-top: 4rem;
            opacity: 0.5;
            font-size: 0.85rem;
            letter-spacing: 1px;
        }

        @media (max-width: 768px) {
            .navbar { flex-direction: column; gap: 1rem; }
            .header { height: 50vh; }
        }
    </style>
</head>
<body>

  <nav class="navbar">
    <a href="#" class="logo">PNW Stroller Trails</a>
    <div class="nav-links">
        <a href="#">Home</a>
        <a href="#">Seattle</a>
        <a href="https://www.alltrails.com/us/oregon/portland/strollers" target="_blank">Portland</a>
        <a href="https://www.alltrails.com/us/washington/bellingham/strollers" target="_blank">Bellingham</a>
        <a href="#">Contact</a>
    </div>
  </nav>

  <header class="header">
    <h1>Explore the Wild,<br>Stroller Friendly Trails.</h1>
    <p>A curated collection of Pacific Northwest trails designed for parents who refuse to trade the forest for the sidewalk.</p>
  </header>

  <main>
    <section class="quote-container">
      <h3>
        "After the birth of my first child, I worried I’d be stuck on pavement forever. My quest began to find those 'Goldilocks' trails—wide enough for a stroller, but with enough earth and gravel to feel like a real trail run again."
      </h3>
    </section>

    <section class="row">
      <div class="column">
        <img src="https://images.unsplash.com/photo-1600563093202-337471bde37e?q=80&w=2012&auto=format&fit=crop" alt="Stroller Gear">
        <div class="column-text">
          <h2>Gear Recommendations</h2>
          <p>The best all-terrain strollers and essential kits for PNW weather.</p>
        </div>
      </div>

      <div class="column">
        <img src="https://cdn-assets.alltrails.com/static-map/production/lists/13932834/lists-13932834-20201115195437000000000-625x365-1.png" alt="Seattle Map">
        <div class="column-text">
          <h2>Seattle Area Map</h2>
          <p>Interactive guide to the best flat-grade forest loops in King County.</p>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <h2>Know another trail?</h2>
    <p style="color: var(--text-muted); margin-bottom: 2rem;">Help our community grow by sharing your favorite spot below.</p>

    <div class="comment-section">
        <div id="comment-container">
            <!-- New comments will appear here -->
        </div>

        <textarea id="new-comment" placeholder="Name of trail, location, and why you love it..."></textarea>
        <button id="btn-post">Share Trail</button>
    </div>

    <div class="copyright">
        <p>&copy; 2026 MDY | Stroller Trails PNW</p>
    </div>
  </footer>

  <script>
    document.getElementById("btn-post").addEventListener("click", function () {
        const commentInput = document.getElementById("new-comment");
        const commentText = commentInput.value.trim();
        
        if (commentText !== "") {
            const container = document.getElementById("comment-container");
            const newComment = document.createElement("span");
            newComment.className = "comment-bubble";
            newComment.innerText = commentText;
            container.appendChild(newComment);
            commentInput.value = "";
        }
    });
  </script>

</body>
</html>
